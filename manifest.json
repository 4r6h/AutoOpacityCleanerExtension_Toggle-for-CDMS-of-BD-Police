{
  "manifest_version": 3,
  "name": "Auto Opacity and CD Cleaner",
  "version": "1.2",
  "description": "Sets opacity to 1.0 and removes CD-related elements from CDMS. Double-click to enable Auto Mode.",
  "permissions": ["scripting", "tabs", "storage"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Clean CDMS Page"
  },
  "content_scripts": [
    {
      "matches": ["https://cdms.police.gov.bd/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
